{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd /tmp/playeng3000/frontend && npx vite --port 8080 --host"],
      "port": 8080
