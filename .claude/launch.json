{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd /tmp/playeng3000/frontend && REACT_APP_API_URL=http://localhost:5001/api PORT=3001 npm start"],
      "port": 3001
    },
    {
      "name": "backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd /tmp/playeng3000/backend && FLASK_APP=app.py python3 -m flask run --host 0.0.0.0 --port 5001"],
      "port": 5001
    }
  ]
}
