    {
      "name": "backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd /tmp/playeng3000/backend && FLASK_APP=app.py python3 -m flask run --host 0.0.0.0 --port 5001"],
      "port": 5001
    }
  ]
}
