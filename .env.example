# PlayENG 3000 — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# =====================
# DATABASE
# =====================
DB_PASSWORD=your-strong-random-password-here

# =====================
# FLASK SECRETS
# =====================
SECRET_KEY=your-random-secret-key-here
JWT_SECRET_KEY=your-random-jwt-secret-here

# =====================
# GOOGLE OAUTH
# =====================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =====================
# FACEBOOK OAUTH
# =====================
# Get from: https://developers.facebook.com/apps
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# =====================
# APPLE SIGN IN
# =====================
# Get from: https://developer.apple.com
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# =====================
# OTP SIMPLEPAY
# =====================
# Get from: https://simplepay.hu/fejlesztoknek
SIMPLEPAY_MERCHANT_ID=
SIMPLEPAY_SECRET_KEY=
SIMPLEPAY_SANDBOX=true

# =====================
# CLAUDE API (AI TUTOR)
# =====================
# Get from: https://console.anthropic.com
CLAUDE_API_KEY=

# =====================
# DOMAIN / WEBAUTHN
# =====================
ALLOWED_ORIGINS=https://angolozzunk.hu,https://www.angolozzunk.hu
RP_ID=angolozzunk.hu
RP_ORIGIN=https://angolozzunk.hu
